{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "cli",
    "_description": "AgentForge — AI Agent Orchestration on Nosana's decentralized GPU network. Deploys multi-agent DAG pipelines via @nosana/kit SDK. Set NOSANA_API_KEY via deploy.nosana.com/account/ for sub-agent deployment.",
    "_docker_hub": "https://hub.docker.com/r/drewdockerus/agent-challenge"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "agentforge",
      "args": {
        "image": "drewdockerus/agent-challenge:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "nosana",
          "OPENAI_API_URL": "$OPENAI_API_URL",
          "MODEL_NAME": "Qwen3.5-27B-AWQ-4bit",
          "NOSANA_API_KEY": "$NOSANA_API_KEY",
          "AGENTFORGE_WORKER_IMAGE": "drewdockerus/agentforge-worker:latest",
          "TAVILY_API_KEY": "",
          "TTS_API_KEY": "",
          "IMAGE_API_KEY": "",
          "SERVER_PORT": "3000",
          "FLEET_API_PORT": "3001",
          "FAL_KEY": "",
          "TELEGRAM_BOT_TOKEN": ""
        }
      }
    }
  ]
}
