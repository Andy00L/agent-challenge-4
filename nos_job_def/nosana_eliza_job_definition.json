{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "dashboard",
    "_description": "AgentForge — AI Agent Orchestration on Nosana's decentralized GPU network. Deploys multi-agent DAG pipelines via @nosana/kit SDK. Set NOSANA_API_KEY via deploy.nosana.com/account/ for sub-agent deployment.",
    "_docker_hub": "https://hub.docker.com/r/drewdockerus/agent-challenge"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "agentforge",
      "args": {
        "image": "drewdockerus/agent-challenge:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "ollama",
          "OPENAI_API_URL": "https://53nd6xcjkgmbhgfwj4mkzmdzkykybg1vg3pe6fzrdsma.node.k8s.prd.nos.ci/v1",
          "MODEL_NAME": "gemma4:26b",
          "NOSANA_API_KEY": "<YOUR_NOSANA_API_KEY>",
          "AGENTFORGE_WORKER_IMAGE": "drewdockerus/agent-challenge:latest",
          "TAVILY_API_KEY": "<YOUR_TAVILY_KEY>",
          "TTS_API_KEY": "<YOUR_OPENAI_KEY>",
          "IMAGE_API_KEY": "<YOUR_OPENAI_KEY>",
          "SERVER_PORT": "3000",
          "FLEET_API_PORT": "3001",
          "FAL_KEY": "",
          "TELEGRAM_BOT_TOKEN": ""
        }
      }
    }
  ]
}
