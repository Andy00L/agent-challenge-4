# =============================================================
# AgentForge — Environment Variables
# =============================================================

# -------------------------------------------------------------
# Web Search (Tavily) — used by plugin-web-search
# -------------------------------------------------------------
TAVILY_API_KEY=

# -------------------------------------------------------------
# LLM Configuration — Qwen3.5-27B via Nosana Inference Endpoint
# -------------------------------------------------------------
# IMPORTANT: @elizaos/plugin-openai reads OPENAI_BASE_URL, not OPENAI_API_URL.
# It reads OPENAI_SMALL_MODEL / OPENAI_LARGE_MODEL, not MODEL_NAME.
OPENAI_API_KEY=nosana
OPENAI_BASE_URL=https://6vq2bcqphcansrs9b88ztxfs88oqy7etah2ugudytv2x.node.k8s.prd.nos.ci/v1
OPENAI_SMALL_MODEL=Qwen3.5-27B-AWQ-4bit
OPENAI_LARGE_MODEL=Qwen3.5-27B-AWQ-4bit

# Legacy names — passed to worker container env vars
MODEL_NAME=Qwen3.5-27B-AWQ-4bit
OPENAI_API_URL=https://6vq2bcqphcansrs9b88ztxfs88oqy7etah2ugudytv2x.node.k8s.prd.nos.ci/v1

# -------------------------------------------------------------
# Agent Server Configuration
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# Nosana API — get your key at https://deploy.nosana.com/account/
# Leave empty for mock mode (local development without deployments)
# -------------------------------------------------------------
NOSANA_API_KEY=

# -------------------------------------------------------------
# Docker image for spawned agent workers
# -------------------------------------------------------------
AGENTFORGE_WORKER_IMAGE=drewdockerus/agentforge-worker:latest

# -------------------------------------------------------------
# Fleet API server port (standalone fallback when plugin routes aren't mounted)
# -------------------------------------------------------------
FLEET_API_PORT=3001

# -------------------------------------------------------------
# Optional: Local development with Ollama
# -------------------------------------------------------------
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_SMALL_MODEL=qwen3.5:27b
# OPENAI_LARGE_MODEL=qwen3.5:27b
