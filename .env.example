# =============================================================
# AgentForge - Environment Variables
# =============================================================
# All LLM/API keys are forwarded to worker containers on Nosana GPUs.
# Workers use YOUR config - no hardcoded defaults.

# =============================================================
# LLM Configuration
# =============================================================
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_API_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# =============================================================
# Web Search (required for researcher agents)
# =============================================================
TAVILY_API_KEY=tvly-your-key-here

# =============================================================
# Agent Server Configuration
# =============================================================
SERVER_PORT=3000

# =============================================================
# Nosana GPU Network
# =============================================================
# Get your key at https://deploy.nosana.com/account/
# Leave empty for mock mode (local development without deployments)
NOSANA_API_KEY=
AGENTFORGE_WORKER_IMAGE=drewdockerus/agentforge-worker:latest

# =============================================================
# Fleet API
# =============================================================
FLEET_API_PORT=3001
# CORS_ORIGIN=http://localhost:5173
# FLEET_API_TOKEN=your-secret-token

# =============================================================
# TTS / Audio (optional)
# =============================================================
# Single key, auto-detects provider from format:
#   sk_ prefix = ElevenLabs (best quality, word-level timestamps)
#   sk- prefix = OpenAI TTS (calls api.openai.com, NOT the LLM endpoint)
#   fal_ or key_ prefix = fal.ai PlayAI
# Fallback: Coqui TTS on Nosana GPU (uses NOSANA_API_KEY, deploys automatically)
# If none configured: TTS is skipped, narrator returns text only
# TTS_API_KEY=

# =============================================================
# Image Generation (all optional, checked in priority order)
# =============================================================
# Single key, auto-detects provider from format:
#   sk- prefix = OpenAI DALL-E 3 ($0.04/image, skips ComfyUI GPU deployment)
# If not set, falls back to: ComfyUI on Nosana GPU → fal.ai → manual endpoint
# IMAGE_API_KEY=
#
# Full priority chain:
# Priority 0: IMAGE_API_KEY (if set, tries DALL-E 3 first)
# Priority 1: ComfyUI SD 1.5 on Nosana GPU (warm container, if already booted)
# Priority 2: ComfyUI SD 1.5 on Nosana GPU (fresh deploy, uses NOSANA_API_KEY)
# Priority 3: DALL-E 3 - uses OPENAI_API_KEY when OPENAI_API_URL points to api.openai.com
# Priority 4: fal.ai Flux - set FAL_KEY
# Priority 5: Manual ComfyUI/A1111 endpoint
# FAL_KEY=
# COMFYUI_ENDPOINT=https://xxx.node.k8s.prd.nos.ci
# A1111_ENDPOINT=https://xxx.node.k8s.prd.nos.ci

# =============================================================
# Video Generation (not yet implemented)
# =============================================================
# WAN_VIDEO_ENDPOINT=https://xxx.node.k8s.prd.nos.ci

# --- Telegram (optional) ---
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# =============================================================
# Alternative: Local development with Ollama
# =============================================================
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3.5:27b
