{
  "name": "agentforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently --kill-others \"elizaos dev\" \"cd frontend && npm run dev\"",
    "dev:backend": "elizaos dev",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "elizaos start",
    "build:frontend": "cd frontend && npm run build",
    "build": "tsc && cd frontend && npm run build",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@elizaos/core": "^1.0.0",
    "@elizaos/plugin-anthropic": "^1.5.12",
    "@elizaos/plugin-bootstrap": "^1.0.0",
    "@elizaos/plugin-openai": "^1.0.0",
    "@elizaos/plugin-web-search": "^1.0.1",
    "@nosana/kit": "^2.2.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "patch-package": "^8.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@elizaos/cli": "^1.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.0.0"
  },
  "patchedDependencies": {
    "@elizaos/plugin-openai@1.6.0": "patches/@elizaos%2Fplugin-openai@1.6.0.patch",
    "@ai-sdk/openai@2.0.101": "patches/@ai-sdk%2Fopenai@2.0.101.patch"
  }
}
